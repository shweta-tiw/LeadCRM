<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - LeadCRM</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="~/Content/site.css" rel="stylesheet">
</head>

<body>
    @if (ViewBag.IsAuthPage == true)
    {
        <div class="auth-page d-flex align-items-center justify-content-center vh-100">
            @RenderBody()
        </div>
    }
    else
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-gradient">
            <a class="navbar-brand" href="#">LeadCRM</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/Account/Logout">Logout</a></li>
                </ul>
            </div>
        </nav>

        <div class="d-flex">
            <div class="sidebar p-3 bg-dark text-white vh-100">
                <a class="d-block text-white mb-2" href="/Dashboard/Dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                <a class="d-block text-white mb-2" href="/Leads/Index"><i class="fas fa-users"></i> Leads</a>
                <a class="d-block text-white mb-2" href="/Sales/Index"><i class="fas fa-chart-line"></i> Sales</a>
            </div>

            <div class="container-fluid p-4">
                @RenderBody()
            </div>
        </div>
    }

    <!-- jQuery & Bootstrap JS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>