@{
    Layout = null; // No sidebar/footer
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>CRM Home</title>
    <style>
        /* Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* Full viewport */
        html, body {
            height: 100%;
            width: 100%;
            overflow: hidden; /* No scrolling */
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff;
        }

        /* Center everything */
        .home-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            text-align: center;
            padding: 20px;
        }

        h1 {
            font-size: 3rem;
            margin-bottom: 15px;
        }

        p {
            font-size: 1.2rem;
            margin-bottom: 30px;
            max-width: 600px;
        }

        /* CTA Buttons */
        .cta-buttons {
            display: flex;
            gap: 20px;
            margin-bottom: 50px;
        }

            .cta-buttons a {
                padding: 12px 30px;
                border-radius: 30px;
                text-decoration: none;
                font-weight: bold;
                transition: all 0.3s;
            }

        .btn-primary {
            background: #ff6b6b;
            color: #fff;
        }

            .btn-primary:hover {
                background: #ff8787;
            }

        .btn-secondary {
            background: transparent;
            color: #fff;
            border: 2px solid #fff;
        }

            .btn-secondary:hover {
                background: rgba(255,255,255,0.2);
            }

        /* Feature cards */
        .cards {
            display: flex;
            gap: 20px;
            justify-content: center;
        }

        .card {
            background: rgba(255,255,255,0.1);
            border-radius: 15px;
            padding: 30px;
            width: 220px;
            text-align: center;
            cursor: pointer;
            transition: transform 0.3s, background 0.3s;
        }

            .card:hover {
                transform: translateY(-10px);
                background: rgba(255,255,255,0.2);
            }
    </style>
</head>
<body>
    <div class="home-container">
        <h1>Boost Your Sales with Our CRM</h1>
        <p>Manage leads, track deals, collaborate with your team, and grow your business efficiently — all in one platform.</p>

        <div class="cta-buttons">
            <a href="/Account/Register" class="btn-primary">Get Started</a>
            <a href="/Account/Login" class="btn-secondary">Login</a>
        </div>

        <div class="cards">
            <div class="card">Lead Management</div>
            <div class="card">Sales Dashboard</div>
            <div class="card">Analytics & Reports</div>
            <div class="card">Team Collaboration</div>
        </div>
    </div>
</body>
</html>