@model dynamic
@{
    ViewBag.Title = "Add Lead";

}

<div class="vh-100 d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="card add-lead-card shadow-lg p-5">
        <h3 class="text-center mb-4 fw-bold text-primary">Add New Lead</h3>

        @using (Html.BeginForm("Add", "Leads", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
           

                <div class="mb-3">
                    <label class="form-label fw-semibold">Name</label>
                    <input type="text" name="Name" class="form-control-lg form-input" placeholder="Enter full name" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Email</label>
                    <input type="email" name="Email" class="form-control-lg form-input" placeholder="Enter email address" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Phone</label>
                    <input type="text" name="Phone" class="form-control-lg form-input" placeholder="Enter phone number" required />
                </div>

                <div class="d-grid gap-3 mt-4">
                    <button type="submit" class="btn btn-primary btn-lg btn-shadow">Save Lead</button>
                    <a href="@Url.Action("Index", "Leads")" class="btn btn-outline-primary btn-lg btn-shadow">Back</a>
                </div>
        }
    </div>
</div>

<style>
    body {
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    .add-lead-card {
        width: 100%;
        max-width: 450px;
        border-radius: 20px;
        background: #fff;
        padding: 40px 30px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .add-lead-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 50px rgba(0,0,0,0.25);
        }

    h3 {
        font-size: 1.8rem;
    }

    .form-label {
        font-size: 0.95rem;
        color: #555;
    }

    .form-input {
        width: 100%;
        border-radius: 12px;
        padding: 12px 15px;
        font-size: 1rem;
        border: 1px solid #ccc;
        transition: border-color 0.3s, box-shadow 0.3s;
        outline: none;
    }

        .form-input:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.2);
        }

    .btn-shadow {
        border-radius: 12px;
        transition: all 0.3s ease;
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
    }

        .btn-shadow:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.2);
        }
</style>