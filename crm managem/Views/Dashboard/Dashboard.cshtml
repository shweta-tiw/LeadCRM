@{
    ViewBag.Title = "Dashboard";
    Layout = null; // No sidebar/footer
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Dashboard - CRM</title>

    <!-- FontAwesome & Bootstrap -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f4f6f9;
            color: #333;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            background: #fff;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 30px rgba(0,0,0,0.12);
            }

            .card i {
                font-size: 30px;
                margin-bottom: 10px;
                color: #667eea;
            }

            .card h4 {
                font-size: 16px;
                color: #777;
                margin-bottom: 10px;
            }

            .card h2 {
                font-size: 32px;
                font-weight: 700;
            }

        .chart-container {
            background: #fff;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        }

        .dashboard-actions {
            text-align: center;
            margin-bottom: 40px;
        }

            .dashboard-actions .btn {
                margin: 5px;
                font-size: 16px;
                padding: 10px 20px;
                border-radius: 10px;
            }

        .navbar-brand {
            font-weight: bold;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand" href="#">CRM Dashboard</a>
            <div class="d-flex align-items-center">
                <span class="me-3">@Session["FullName"] @(string.IsNullOrEmpty(Session["Role"]?.ToString()) ? "" : "(" + Session["Role"] + ")")</span>
                <a href="@Url.Action("Logout","Account")" class="btn btn-outline-primary btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container">

        <!-- Quick action buttons -->
        <div class="dashboard-actions">
            <a href="@Url.Action("Create","Leads")" class="btn btn-primary"><i class="fas fa-plus"></i> Add Lead</a>
            <a href="@Url.Action("Index","Leads")" class="btn btn-success"><i class="fas fa-users"></i> Manage Leads</a>
        </div>

        <!-- Metric cards -->
        <div class="cards">
            <div class="card" onclick="window.location='@Url.Action("Index","Leads")'">
                <i class="fas fa-users"></i>
                <h4>Total Leads</h4>
                <h2>@ViewBag.TotalLeads</h2>
            </div>
            <div class="card" onclick="window.location='@Url.Action("Index","Leads")?status=New'">
                <i class="fas fa-user-plus"></i>
                <h4>New Leads</h4>
                <h2>@ViewBag.New</h2>
            </div>
            <div class="card" onclick="window.location='@Url.Action("Index","Leads")?status=Contacted'">
                <i class="fas fa-phone"></i>
                <h4>Contacted</h4>
                <h2>@ViewBag.Contacted</h2>
            </div>
            <div class="card" onclick="window.location='@Url.Action("Index","Leads")?status=Won'">
                <i class="fas fa-trophy"></i>
                <h4>Won</h4>
                <h2>@ViewBag.Won</h2>
            </div>
            <div class="card" onclick="window.location='@Url.Action("Index","Leads")?status=Lost'">
                <i class="fas fa-times-circle"></i>
                <h4>Lost</h4>
                <h2>@ViewBag.Lost</h2>
            </div>
        </div>

        <!-- Lead status chart -->
        <!-- Lead status chart -->
        <div class="chart-container mx-auto" style="max-width: 500px;">
            <canvas id="leadChart"></canvas>
        </div>  

    </div>

    <script>
    var ctx = document.getElementById('leadChart').getContext('2d');

    // Convert Razor ViewBag values to integers safely
    var newLeads = @((ViewBag.New ?? 0));
    var contacted = @((ViewBag.Contacted ?? 0));
    var won = @((ViewBag.Won ?? 0));
    var lost = @((ViewBag.Lost ?? 0));

    var chart = new Chart(ctx, {
        type: 'pie',
        data: {
            labels: ['New', 'Contacted', 'Won', 'Lost'],
            datasets: [{
                label: 'Lead Status',
                data: [newLeads, contacted, won, lost],
                backgroundColor: ['#f39c12','#3498db','#2ecc71','#e74c3c'],
                borderColor:'#fff',
                borderWidth:2
            }]
        },
        options: {
            responsive:true,
            plugins:{
                legend:{ position:'bottom' },
                title:{ display:true, text:'Lead Status Distribution', font:{ size:18 } }
            }
        }
    });
    </script>
</body>
</html>